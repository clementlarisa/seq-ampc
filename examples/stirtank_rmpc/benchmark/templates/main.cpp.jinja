bool inStateConstr(const Eigen::Matrix<float,NX, N>& X){
    return ((Lx * X).array() <= (1 + eps)).all();
};


bool inTerminalConstr( const Eigen::Vector<float, NX>& x){
    return ( x.transpose() * P * x - alphaSquared ) <= eps;
};

bool feasible(const Eigen::Matrix<float, NX, N+1>& X){
    bool feasInState = inStateConstr(X.block(0,0,NX,N));
    bool feasInTerm  = inTerminalConstr(X.col(N));
    // std::cout << "feasInState " << feasInState << " feasInTerm " << feasInTerm << std::endl;
    return feasInState && feasInTerm;
}

float stateCost(const Eigen::Matrix<float, NX, N>& X, const Eigen::Matrix<float, NX, NX>& Q){
    const Eigen::Matrix<float, NX, N> QX = Q*X;
    Eigen::Matrix<float, 1, N> XtQX;
    for (size_t ii=0; ii<N; ii++){
        XtQX(0,ii) = X.col(ii).dot(QX.col(ii));
    }
    return XtQX.sum();
};

float inputCost(const Eigen::Matrix<float, NU, N>& U, const Eigen::Matrix<float, NU, NU>& R){
    const Eigen::Matrix<float, NU, N> RU = R*U;
    Eigen::Matrix<float, 1, N> UtRU;
    for (size_t ii=0; ii<N; ii++){
         UtRU(0,ii) = U.col(ii).dot(RU.col(ii));
    }
    return UtRU.sum();
};

float terminalCost(const Eigen::Vector<float, NX> x, const Eigen::Matrix<float, NX, NX>& P){
    return x.transpose()*P*x;
};

float cost(const Eigen::Matrix<float, NX, N+1>& X, const Eigen::Matrix<float, NU, N>& U)
{
    return stateCost(X.block(0,0,NX,N),Q) + inputCost(U,R) + terminalCost(X.col(N), P);
};

void saveData(std::string fileName, Eigen::MatrixXf  matrix){
    const static Eigen::IOFormat CSVFormat(Eigen::FullPrecision, Eigen::DontAlignCols, ", ", "\n");
 
    std::ofstream file(fileName);
    if (file.is_open())
    {
        file << matrix.format(CSVFormat);
        file.close();
    }
};

std::vector<Eigen::Vector<float, NX>> readCSV(const std::string& fileName, const size_t max_values=1000) {
    std::ifstream file(fileName);
    std::vector<Eigen::Vector<float, NX>> x0_values;
    std::string line;
    
    while (std::getline(file, line), x0_values.size() < max_values) {
        std::stringstream lineStream(line);
        Eigen::Vector<float, NX> x0;
        for (std::size_t i = 0; i < NX; ++i) {
            std::string cell;
            std::getline(lineStream, cell, ',');
            x0[i] = std::stof(cell);
        }
        x0_values.push_back(x0);
    }
    return x0_values;
}

int main(int argc, char* argv[]) {
    acados_sim::acadosSimInit();

    if (argc < 2) {
        std::cerr << "Usage: " << argv[0] << " <csvFileName>" << std::endl;
        return 1;
    }

    std::string csvFileName = argv[1];
    std::vector<Eigen::Vector<float, NX>> x0_values = readCSV(csvFileName);

    Eigen::Matrix<float, NX, N+1> X_cand;
    Eigen::Matrix<float, NX, N+1> X_pred;

    Eigen::Matrix<float, NU, N> U_cand;
    Eigen::Matrix<float, NU, N> U_pred;
    Eigen::Matrix<float, NU, N> V_pred;

    std::chrono::duration<double> total_inf_time{0};
    std::chrono::duration<double> total_aug_time{0};
    std::size_t total_iterations = 0;

    for (Eigen::Vector<float,NX> x0 : x0_values) {
        float candidate_cost = 0;
        X_cand.col(0) = x0;
        X_pred.col(0) = x0;
        bool candidate_feasible = false;
        std::array<std::chrono::duration<double>, Nsim> inf_times;
        std::array<std::chrono::duration<double>, Nsim> aug_times;

        Eigen::Matrix<float, NX, Nsim> X_sim;
        Eigen::Matrix<float, NU, Nsim> U_sim;

        for (std::size_t tt=0; tt < Nsim; tt++ ){
            const auto start_inference = std::chrono::high_resolution_clock::now();
            
            // std::cout << "Iter: " << tt << std::endl;
            x0 = X_cand.col(0);
            // std::cout << "x0 = "<< x0.transpose() << std::endl;
            const auto x0_normalized = embedded_nn_inference::stirtank_nn::normalize_input(x0);
            const auto output = embedded_nn_inference::stirtank_nn::call_nn(x0_normalized);
            V_pred = embedded_nn_inference::stirtank_nn::reshape_output(output).transpose();
            for (std::size_t ii=0; ii<N; ii++){
                V_pred.col(ii) = embedded_nn_inference::stirtank_nn::denormalize_output(V_pred.col(ii));
            }
    
            const auto end_inference = std::chrono::high_resolution_clock::now();
            inf_times.at(tt) = end_inference-start_inference;
    
            const auto start_aug = std::chrono::high_resolution_clock::now();
            X_pred.col(0) = x0;
            forwardSimulateTrajectoryClippedInputs(X_pred, U_pred, V_pred);
    
            // std::cout << "U_pred = \n"<< U_pred.transpose() << std::endl;
            // std::cout << "\n\nX_pred = \n"<< X_pred.transpose() << std::endl;
    
            bool predicted_feasible = feasible(X_pred);
            float predicted_cost = cost(X_pred, U_pred);
    
            if ( (predicted_feasible && (predicted_cost <= candidate_cost))
                || !candidate_feasible){
                X_cand = X_pred;
                U_cand = U_pred;
                candidate_feasible = predicted_feasible;
                
            };
    
            X_sim.col(tt) = X_cand.col(0);
            U_sim.col(tt) = U_cand.col(0);
    
            shiftAppendTerminalInPlace(X_cand, U_cand);
    
            const auto end_aug = std::chrono::high_resolution_clock::now();
            aug_times.at(tt) = end_aug - start_aug;
        }
            
        for(std::size_t tt=0; tt<Nsim; tt++){
            total_aug_time += aug_times.at(tt);
            total_inf_time += inf_times.at(tt);
        }
        total_iterations += Nsim; // Account for all time steps for this x0

        // saveData(std::string{"X_sim.csv"}, X_sim.transpose());
        // saveData(std::string{"U_sim.csv"}, U_sim.transpose());
    }

    std::cout << "Inference avg. time " << total_inf_time/total_iterations << std::endl;
    std::cout << "Augmentation avg. time " << total_aug_time/total_iterations << std::endl;
}