static constexpr std::size_t NX{STIRTANK_NX};
static constexpr std::size_t NZ{STIRTANK_NZ};
static constexpr std::size_t NU{STIRTANK_NU};
static constexpr std::size_t NP{STIRTANK_NP};
static constexpr std::size_t N{10};
static constexpr std::size_t Nsim{30};

static const Eigen::Matrix<float, NX, NX>Q{{Q}};
static const Eigen::Matrix<float, NX, NX>P{{P}};
static const Eigen::Matrix<float, NU, NU>R{{R}};
static const Eigen::Matrix<float, NU, NX>K{{K}};
static const Eigen::Matrix<float, NU, NX>Kdelta{{Kdelta}};
static const Eigen::Matrix<float, NU, NX>KmKdelta{K-Kdelta};
static const float alpha{ {{alpha}} };
static const float alphaSquared = alpha*alpha;
//static const Eigen::Matrix<float, {{nconstr}} , NU> Lu{{Lu}};
static const Eigen::Matrix<float, {{nconstr}} , NX> Lx{{Lx}};
static const Eigen::Vector<float, NU> u_max{ {{u_max}} };
static const Eigen::Vector<float, NU> u_min{ {{u_min}} };
//static const Eigen::Vector<float, NX> x_max{ {{x_max}} };
//static const Eigen::Vector<float, NX> x_min{ {{x_min}} };
static const float eps{1e-4};

namespace acados_sim {

    int status = 0;
    sim_solver_capsule *capsule;
    sim_config *acados_sim_config;
    sim_opts *acados_sim_opts;
    sim_in *acados_sim_in;
    sim_out *acados_sim_out;
    void *acados_sim_dims;
    
    void acadosSimInit(){
        capsule  = stirtank_acados_sim_solver_create_capsule();
        status = stirtank_acados_sim_create(capsule);
        if (status)
        {
            printf("acados_create() returned status %d. Exiting.\n", status);
            exit(1);
        }
        acados_sim_config = stirtank_acados_get_sim_config(capsule);
        acados_sim_opts = stirtank_acados_get_sim_opts(capsule);
        // acados_sim_opts->newton_iter=2;
        // acados_sim_opts->newton_tol=5e-2;
        acados_sim_in = stirtank_acados_get_sim_in(capsule);
        acados_sim_out = stirtank_acados_get_sim_out(capsule);
        acados_sim_dims = stirtank_acados_get_sim_dims(capsule);
    };

}; // namespace acados_sim

// Eigen::Matrix<float, NX, N> 
void
forwardSimulateTrajectoryClippedInputs(Eigen::Matrix<float, NX, N+1>& X, Eigen::Matrix<float, NU, N>& U, Eigen::Matrix<float, NU, N>& V){
    for (std::size_t ii=0; ii < N; ii++){
        U.col(ii) = (Kdelta*X.col(ii)+V.col(ii)).cwiseMin(u_max).cwiseMax(u_min);
        V.col(ii) = U.col(ii) - Kdelta*X.col(ii);
        Eigen::Vector<double, NX> x_double = X.col(ii).cast<double>();
        Eigen::Vector<double, NU> v_double = V.col(ii).cast<double>();

        sim_in_set(acados_sim::acados_sim_config, acados_sim::acados_sim_dims,
            acados_sim::acados_sim_in, "x", x_double.data());
        sim_in_set(acados_sim::acados_sim_config, acados_sim::acados_sim_dims,
            acados_sim::acados_sim_in, "u", v_double.data());
        acados_sim::status = stirtank_acados_sim_solve(acados_sim::capsule);
        if (acados_sim::status != ACADOS_SUCCESS)
        {
            printf("acados_solve() failed with status %d.\n", acados_sim::status);
        }
        Eigen::Vector<double, NX> x_double_next;
        sim_out_get(acados_sim::acados_sim_config, acados_sim::acados_sim_dims,
               acados_sim::acados_sim_out, "x", x_double_next.data());
        X.col(ii+1) = x_double_next.cast<float>();
    }
}

void shiftAppendTerminalInPlace(Eigen::Matrix<float, NX, N+1>& X, Eigen::Matrix<float, NU, N>& U){
    X.block(0,0,NX,N) = X.block(0, 1, NX, N); // shift
    U.block(0,0,NU,N-1) = U.block(0, 1, NU, N-1); //shift
    U.col(N-1) = (KmKdelta*X.col(N-1)).cwiseMin(u_max).cwiseMax(u_min); // terminal controller

    Eigen::Vector<double, NX> x_double = X.col(N-1).cast<double>();
    Eigen::Vector<double, NU> v_double = (U.col(N-1)-Kdelta*X.col(N-1)).cast<double>();
    // now simulate one timestep
    sim_in_set(acados_sim::acados_sim_config, acados_sim::acados_sim_dims,
    acados_sim::acados_sim_in, "x", x_double.data());
    sim_in_set(acados_sim::acados_sim_config, acados_sim::acados_sim_dims,
        acados_sim::acados_sim_in, "u", v_double.data());
    acados_sim::status = stirtank_acados_sim_solve(acados_sim::capsule);
    if (acados_sim::status != ACADOS_SUCCESS)
    {
        printf("acados_solve() failed with status %d.\n", acados_sim::status);
    }
    Eigen::Vector<double, NX> x_double_res;
    sim_out_get(acados_sim::acados_sim_config, acados_sim::acados_sim_dims,
            acados_sim::acados_sim_out, "x", x_double_res.data());
    X.col(N) = x_double_res.cast<float>();    
}


